{
  "name": "restaurant-signage-mvp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/admin",
    "apps/tv"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:admin\" \"npm run dev:tv\"",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "dev:tv": "npm run dev --workspace=apps/tv",
    "build": "npm run build --workspaces",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
